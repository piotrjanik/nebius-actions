{
  "name": "nebius-actions",
  "version": "0.0.0",
  "private": true,
  "description": "Composable GitHub Actions for Nebius AI Cloud (Jobs and Endpoints).",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/http-client": "^4.0.1",
    "@actions/tool-cache": "^3.0.1",
    "@nebius/js-sdk": "^0.2.27"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
